{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "role": { "type": "string", "enum": ["client", "admin", "worker"], "description": "User role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Service booking request",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who made the booking" },
        "service": { "type": "string", "description": "Type of service (Residential, Commercial, etc.)" },
        "date": { "type": "string", "format": "date", "description": "Scheduled date" },
        "message": { "type": "string", "description": "Additional details" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"], "description": "Current status of the booking" },
        "assignedWorkerId": { "type": "string", "description": "UID of the worker assigned to this booking" },
        "adminNotes": { "type": "string", "description": "Internal notes for admins" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created" }
      },
      "required": ["userId", "service", "date"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Contact form submission from unauthenticated user",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the lead" },
        "email": { "type": "string", "format": "email", "description": "Email address of the lead" },
        "service": { "type": "string", "description": "Service interested in" },
        "date": { "type": "string", "format": "date", "description": "Preferred date" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["name", "email", "service", "date", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service bookings"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Contact form leads"
    }
  }
}
